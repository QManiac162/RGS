{
    "name": "terminal-service",
    "version": "0.1.0",
    "description": "RailGate - Terminal & Capacity Service",
    "private": true,
    "license": "MIT",
    "scripts": {
        "build": "nest build",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:prod": "node dist/main",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "@nestjs/common": "11.1.28",
        "@nestjs/core": "11.1.28",
        "@nestjs/platform-express": "11.1.28",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@nestjs/cli": "11.1.28",
        "@nestjs/schematics": "11.1.28",
        "@nestjs/testing": "11.1.28",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.3",
        "@types/node": "^20.4.2",
        "jest": "^29.6.1",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.2.2"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}